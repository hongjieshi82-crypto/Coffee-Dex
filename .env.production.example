# Copy this file to .env.production on the ECS host. Do not commit the real file.
COFFEE_DEX_LOCAL_AUTH_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: enables shared cloud records and Supabase authentication.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=coffee-photos
